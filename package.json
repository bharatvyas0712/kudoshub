{
	"name": "kudoshub",
	"private": true,
	"version": "1.0.0",
	"description": "KudosHub employee recognition system workspace",
	"workspaces": [
		"backend",
		"frontend"
	],
	"scripts": {
		"dev:backend": "npm run dev --workspace backend",
		"dev:frontend": "npm run dev --workspace frontend",
